# Archivo de Configuración Local (NO versionado)
# Copiar a `lib/config/app_config.dart` después de clonar el repo

# Este archivo contiene datos sensibles y no debe publicarse en GitHub
# Cada desarrollador debe crear su propia copia con sus datos

## BUNDLE ID / APPLICATION ID PRIVADO
# Android: android/app/build.gradle.kts (applicationId)
# iOS: ios/Runner.xcodeproj/project.pbxproj (PRODUCT_BUNDLE_IDENTIFIER)
# Flutter: pub get automaticamente usa estos valores

BUNDLE_ID=com.example.m3e_demo

## SIGNING CONFIGURATION (si aplica)
# Tus certificados y claves de firma NUNCA deben estar en GitHub
# Guardarlos localmente y agregar a .gitignore

KEYSTORE_PATH=/path/to/your/keystore.jks
KEYSTORE_PASSWORD=your_keystore_password
KEY_ALIAS=your_key_alias
KEY_PASSWORD=your_key_password

## DEVELOPER INFORMATION (PRIVATE)
# Tus datos personales como desarrollador

DEVELOPER_NAME=Tu Nombre
DEVELOPER_EMAIL=tu.email@example.com

## API KEYS y SECRETS (si aplica)
# Cualquier API key, token, o secret debe estar aquí

YOUTUBE_API_KEY=your_youtube_api_key_here

## NOTES
# Este archivo es específico de tu máquina de desarrollo
# Los valores por defecto en el repo público son genéricos
# Para builds de producción, actualiza estos valores
